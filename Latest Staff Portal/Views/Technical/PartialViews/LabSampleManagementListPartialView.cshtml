@model IEnumerable<Latest_Staff_Portal.ViewModel.LabSampleManagement>

@{
    ViewBag.Title = "LabSampleManagementListPartialView";
}


<div class="table-responsive">
    <table id="datatable-buttons" class="table table-bordered dt-responsive nowrap" style="border-collapse: collapse; border-spacing: 0; width: 100%;">
        <thead style="background-color:black;color:white">
            <tr>
                <th>Action</th>
                <th>Document No </th> 
                @*<th>Region </th>
                <th>Department </th>*@
                <th>Month </th>
                <th>Status </th>
            </tr>
        </thead>
        <tbody>

            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        <button class="btn btn-primary btn-sm action-buttons2" onclick="ViewDoc('@item.Sample_ID');" >Select</button> 
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.Sample_ID)
                    </td>
                   
                    @*<td>
                        @Html.DisplayFor(modelItem => item.Global_Dimension_1_Code)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.Global_Dimension_2_Code)
                    </td>*@
                    <td>
                        @Html.DisplayFor(modelItem => item.Month_Name)
                    </td>
                  
                    <td>
                        @Html.DisplayFor(modelItem => item.Status)
                    </td>
                 
                </tr>
            }
        </tbody>
    </table>
</div>

<script>
    $("#datatable-buttons").DataTable({
        lengthChange: true,
        lengthMenu: [5, 10, 25, 50, 100] // Same options for the second table
    });
</script>

        }
        ShowProgress();
        //Send the JSON array to Controller using AJAX.
        $.ajax({
            type: "POST",
            url: "/ImprestMemo/UpdateImprestMemoHeader",
            data: JSON.stringify({ DocNo: DocNo, Data: Data }),
            contentType: "application/json; charset=utf-8",
            dataType: "json",
            success: function (data) {
                if (data.success) {

@model Latest_Staff_Portal.ViewModel.SalaryAdvanceModel

@{
    ViewBag.Title = "SalaryAdvanceDocumentView";
    Layout = "~/Views/Shared/Sitemaster.cshtml";
}


<style>
    thead {
        background-color: black;
        color: white;
    }

    hr {
        margin: 4px;
    }

    .BtnPadding {
        padding: 1px;
        font-size: 12px;
    }
</style>

<div class="page-header">
    <div class="row">
        <div class="col-sm-12">
            <ul class="breadcrumb">
                <li class="breadcrumb-item">
                    <a href="/SalaryAdvance/SalaryAdvance">Salary Advance List</a>
                </li>
                <li class="breadcrumb-item active">Salary Advance Document (@Model.Loan_No)</li>
            </ul>
        </div>
    </div>
</div>
<hr />
<br />


<div class="card">
    <div class="card-header">
        <div style="text-align:right">
            @if (Model.Loan_Status == "Application")
            {
                <button class="btn btn-primary btn-sm action-buttons2" onclick="SendForReview('@Model.Loan_No');">
                    <i class="fas fa-paper-plane" aria-hidden="true"></i> Send For Review
                </button>
            }


            @if (Model.Loan_Status == "Pending Approval")
            {
                <button class="btn btn-primary btn-sm action-buttons2" onclick="ViewApprovalTrail('@Model.Loan_No');">
                    <i class="fas fa-list"></i> Approval Trail
                </button>
                <button class="btn btn-danger btn-sm action-buttons2" style="background-color: red" onclick="CancelDocApprovalRequest('@Model.Loan_No');">
                    <i class="fas fa-times"></i> Cancel Approval Request
                </button>
            }

